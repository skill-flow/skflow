{
  "name": "@skflow/runtime",
  "version": "0.2.0",
  "description": "Runtime library for skflow scripts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChikaFujiwara/skflow.git",
    "directory": "packages/runtime"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "default": "./dist/protocol.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc"
  }
}
