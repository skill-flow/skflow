{
  "name": "@ocmdx/runtime",
  "version": "0.1.0",
  "description": "Runtime library for ocmdx scripts",
  "repository": {
    "type": "git",
    "url": "https://github.com/opencmdx/ocmdx.git",
    "directory": "packages/runtime"
  },
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
